<?xml version="1.0" encoding="utf-8"?>
<!--
    Material You / Android 13+ monochrome adaptive icon layer.
    The system automatically tints this drawable to match the user's
    wallpaper-derived theme color when "Themed Icons" is enabled.
    The actual shape comes from ic_launcher_monochrome_bmp.png which is a
    white-on-transparent image extracted from the app's brand icon.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@drawable/ic_launcher_monochrome_bmp"
    android:gravity="center"
    android:tileMode="disabled" />
